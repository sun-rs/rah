{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@rah/runtime-protocol": [
        "packages/runtime-protocol/src/index.ts"
      ]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmitOnError": true
  }
}
