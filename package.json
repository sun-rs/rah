{
  "name": "rah",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "bin": {
    "rah": "./bin/rah.mjs"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "rah": "node ./bin/rah.mjs",
    "build:web": "npm --prefix packages/client-web run build",
    "dev:web": "npm --prefix packages/client-web run dev",
    "dev:daemon": "npm --prefix packages/runtime-daemon run dev",
    "serve:workbench": "npm run build:web && npm run dev:daemon",
    "typecheck": "tsc -p packages/runtime-protocol/tsconfig.json --noEmit && tsc -p packages/runtime-daemon/tsconfig.json --noEmit && tsc -p packages/client-web/tsconfig.json --noEmit",
    "test:web": "node --import tsx --test --test-force-exit packages/client-web/src/types.test.ts packages/client-web/src/useSessionStore.test.ts packages/client-web/src/session-store-sync.test.ts packages/client-web/src/session-store-history.test.ts packages/client-web/src/session-store-history-bootstrap.test.ts packages/client-web/src/session-store-session-startup.test.ts packages/client-web/src/workbench-selectors.test.ts packages/client-web/src/composer-contract.test.ts packages/client-web/src/composer-text-insertion.test.ts packages/client-web/src/session-capabilities.test.ts packages/client-web/src/session-mode-ui.test.ts packages/client-web/src/provider-capabilities.test.ts packages/client-web/src/canvas-state.test.ts packages/client-web/src/council/council-ui-state.test.ts packages/client-web/src/council/council-mentions.test.ts packages/client-web/src/settings-runtime-health.test.ts packages/client-web/src/chat-preferences.test.ts packages/client-web/src/browser-notifications.test.ts packages/client-web/src/terminal-socket-close.test.ts packages/client-web/src/terminal-viewport.test.ts packages/client-web/src/terminal-mobile-bridge.test.ts packages/client-web/src/terminal-shortcuts.test.ts packages/client-web/src/tui-surface-lifecycle.test.ts packages/client-web/src/workbench-notice-contract.test.ts packages/client-web/src/sidebar-layout-contract.test.ts packages/client-web/src/overlay-scroll-area-contract.test.ts packages/client-web/src/sidebar-view-model.test.ts packages/client-web/src/inspector-performance.test.ts packages/client-web/src/session-history-dialog.test.ts packages/client-web/src/local-file-link.test.ts packages/client-web/src/components/chat/assistant-turn-headers.test.ts packages/client-web/src/components/chat/chat-thread-filtering.test.ts packages/client-web/src/components/chat/markdown-blocks.test.ts packages/client-web/src/components/chat/virtualized-feed-layout.test.ts",
    "test:runtime": "node --import tsx --test --test-concurrency=1 --test-force-exit packages/runtime-daemon/src/provider-activity.test.ts packages/runtime-daemon/src/context-usage.test.ts packages/runtime-daemon/src/provider-diagnostics.test.ts packages/runtime-daemon/src/native-tui-diagnostics.test.ts packages/runtime-daemon/src/provider-resume.test.ts packages/runtime-daemon/src/rah-event-contract.test.ts packages/runtime-daemon/src/debug-engine.test.ts packages/runtime-daemon/src/http-server.test.ts packages/runtime-daemon/src/workbench-state.test.ts packages/runtime-daemon/src/host-file-read.test.ts packages/runtime-daemon/src/pty-hub.test.ts packages/runtime-daemon/src/pty-session-runtime.test.ts packages/runtime-daemon/src/tmux-tui-runtime.test.ts packages/runtime-daemon/src/rah-cli-pty-first.test.ts packages/runtime-daemon/src/rah-cli-management.test.ts packages/runtime-daemon/src/history-snapshots.test.ts packages/runtime-daemon/src/history-event-projection.test.ts packages/runtime-daemon/src/timeline-reconciler.test.ts packages/runtime-daemon/src/runtime-session-events.test.ts packages/runtime-daemon/src/native-tui-provider-runtime.test.ts packages/runtime-daemon/src/native-tui-catalog-adapters.test.ts packages/runtime-daemon/src/native-tui-launch-spec.test.ts packages/runtime-daemon/src/native-tui-prompt-state.test.ts packages/runtime-daemon/src/native-tui-mirror-guard.test.ts packages/runtime-daemon/src/native-tui-runtime-config.test.ts packages/runtime-daemon/src/native-tui-session-state.test.ts packages/runtime-daemon/src/runtime-terminal-capabilities.test.ts packages/runtime-daemon/src/session-runtime-descriptor.test.ts packages/runtime-daemon/src/native-local-server-attach.test.ts packages/runtime-daemon/src/runtime-engine.test.ts packages/runtime-daemon/src/runtime-session-list.test.ts packages/runtime-daemon/src/session-mode-utils.test.ts packages/runtime-daemon/src/session-model-options.test.ts packages/runtime-daemon/src/line-history-pager.test.ts packages/runtime-daemon/src/line-history-checkpoint.test.ts packages/runtime-daemon/src/native-terminal-process.test.ts packages/runtime-daemon/src/codex-native-tui-bridge.test.ts packages/runtime-daemon/src/codex-fixtures.test.ts packages/runtime-daemon/src/codex-history-liveness.test.ts packages/runtime-daemon/src/codex-rollout-activity.test.ts packages/runtime-daemon/src/codex-app-server-activity.test.ts packages/runtime-daemon/src/codex-adapter.test.ts packages/runtime-daemon/src/codex-live-client.test.ts packages/runtime-daemon/src/codex-live-rpc.test.ts packages/runtime-daemon/src/codex-stored-sessions.test.ts packages/runtime-daemon/src/opencode-acp-activity.test.ts packages/runtime-daemon/src/opencode-activity.test.ts packages/runtime-daemon/src/opencode-model-catalog.test.ts packages/runtime-daemon/src/opencode-live-client.test.ts packages/runtime-daemon/src/opencode-stored-sessions.test.ts packages/runtime-daemon/src/claude-session-files.test.ts packages/runtime-daemon/src/gemini-model-catalog.test.ts packages/runtime-daemon/src/gemini-session-files.test.ts packages/runtime-daemon/src/council/council-store.test.ts packages/runtime-daemon/src/council/council-mcp-shim.test.ts packages/runtime-daemon/src/council/council-runtime.test.ts packages/runtime-daemon/src/council/council-cli-mcp.test.ts",
    "test:protocol": "node --import tsx --test --test-force-exit packages/runtime-protocol/src/contract.test.ts packages/runtime-protocol/src/live-backend-policy.test.ts",
    "test:native-tui": "bash scripts/native-tui-gate.sh",
    "test:tui-mux-auto": "bash scripts/tui-mux-auto-gate.sh",
    "test:tui-mux": "bash scripts/tui-mux-gate.sh",
    "test:provider-contracts": "node --import tsx --test --test-force-exit packages/runtime-protocol/src/contract.test.ts packages/runtime-protocol/src/live-backend-policy.test.ts packages/runtime-daemon/src/provider-activity.test.ts packages/runtime-daemon/src/native-tui-provider-runtime.test.ts packages/runtime-daemon/src/native-tui-catalog-adapters.test.ts packages/runtime-daemon/src/native-tui-launch-spec.test.ts packages/runtime-daemon/src/runtime-terminal-capabilities.test.ts packages/runtime-daemon/src/native-local-server-attach.test.ts packages/runtime-daemon/src/session-model-options.test.ts packages/runtime-daemon/src/runtime-engine.test.ts packages/runtime-daemon/src/codex-rollout-activity.test.ts packages/runtime-daemon/src/claude-session-files.test.ts packages/runtime-daemon/src/gemini-model-catalog.test.ts packages/runtime-daemon/src/gemini-session-files.test.ts packages/runtime-daemon/src/opencode-activity.test.ts packages/runtime-daemon/src/opencode-stored-sessions.test.ts packages/client-web/src/session-store-history-bootstrap.test.ts packages/client-web/src/session-store-session-startup.test.ts packages/client-web/src/composer-contract.test.ts packages/client-web/src/provider-capabilities.test.ts packages/client-web/src/components/chat/markdown-blocks.test.ts",
    "test:regression:e2e-plan": "tsx scripts/regression_e2e_manifest.ts --check",
    "test:regression:e2e-list": "tsx scripts/regression_e2e_manifest.ts --markdown",
    "test:regression:e2e-browser": "tsx scripts/regression_e2e_browser_gate.ts",
    "test:smoke:history-claim": "bash scripts/history-claim-smoke.sh",
    "test:smoke:inspector-browser": "bash scripts/inspector-browser-smoke.sh",
    "test:smoke:terminal": "tsx scripts/terminal_smoke.ts",
    "test:smoke:native-codex": "tsx scripts/native_codex_smoke.ts",
    "test:smoke:native-codex-browser": "bash scripts/native-codex-browser-smoke.sh",
    "test:smoke:native-providers": "tsx scripts/native_provider_smoke.ts",
    "test:smoke:native-provider-browser": "bash scripts/native-provider-browser-smoke.sh",
    "test:smoke:native-browser": "npm run test:smoke:native-codex-browser && npm run test:smoke:native-provider-browser",
    "test:smoke:native-browser-webkit": "RAH_NATIVE_BROWSER=webkit npm run test:smoke:native-codex-browser && RAH_NATIVE_BROWSER=webkit npm run test:smoke:native-provider-browser",
    "test:smoke:native-browser-firefox": "RAH_NATIVE_BROWSER=firefox npm run test:smoke:native-codex-browser && RAH_NATIVE_BROWSER=firefox npm run test:smoke:native-provider-browser",
    "test:smoke:tui-surface-lifecycle-browser": "python3 scripts/tui_surface_lifecycle_browser_smoke.py",
    "test:smoke:native-cli-probe": "tsx scripts/native_cli_probe.ts",
    "test:smoke:native-local-server": "tsx scripts/native_local_server_probe.ts",
    "test:smoke:session-control-capabilities": "tsx scripts/session_control_capability_probe.ts",
    "test:smoke:session-control-token-order": "RAH_SESSION_CONTROL_REQUIRE_TOKEN_ORDER=1 tsx scripts/session_control_capability_probe.ts",
    "test:smoke:native-real-tui-launch": "tsx scripts/native_real_tui_launch_probe.ts",
    "test:smoke:native-qa-status": "tsx scripts/native_qa_status.ts",
    "test:smoke:native-manual-qa-status": "tsx scripts/native_manual_qa_status.ts",
    "test:manual-qa-status": "node --import tsx --test --test-force-exit scripts/native_manual_qa_status.test.ts",
    "test:smoke:terminal-browser": "bash scripts/terminal-browser-smoke.sh",
    "test:smoke:tool-flow": "bash scripts/tool-flow-smoke.sh",
    "test:smoke:claude-flow": "bash scripts/claude-flow-smoke.sh",
    "test:smoke:claude-browser": "bash scripts/claude-browser-smoke.sh",
    "test:smoke:codex-browser": "bash scripts/codex-browser-smoke.sh",
    "test:smoke:opencode-browser": "bash scripts/opencode-browser-smoke.sh",
    "test:smoke:browser-providers": "npm run test:smoke:native-browser",
    "test:smoke:real-browser-providers": "npm run test:smoke:codex-browser && npm run test:smoke:claude-browser && npm run test:smoke:opencode-browser",
    "test:smoke:provider-flows": "npm run test:smoke:codex-browser && npm run test:smoke:claude-flow && npm run test:smoke:opencode-browser",
    "test:smoke-cleanup": "python3 -m unittest scripts/rah_smoke_cleanup_test.py",
    "cleanup:smoke-state": "python3 scripts/cleanup_temp_rah_state.py"
  },
  "dependencies": {
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
