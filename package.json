{
  "name": "rah",
  "private": true,
  "type": "module",
  "bin": {
    "rah": "./bin/rah.mjs"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "rah": "node ./bin/rah.mjs",
    "build:web": "npm --prefix packages/client-web run build",
    "dev:web": "npm --prefix packages/client-web run dev",
    "dev:daemon": "npm --prefix packages/runtime-daemon run dev",
    "serve:workbench": "npm run build:web && npm run dev:daemon",
    "typecheck": "tsc -p packages/runtime-protocol/tsconfig.json --noEmit && tsc -p packages/runtime-daemon/tsconfig.json --noEmit && tsc -p packages/client-web/tsconfig.json --noEmit",
    "test:web": "node --import tsx --test --test-force-exit packages/client-web/src/types.test.ts packages/client-web/src/useSessionStore.test.ts packages/client-web/src/session-store-sync.test.ts packages/client-web/src/workbench-selectors.test.ts packages/client-web/src/composer-contract.test.ts packages/client-web/src/composer-text-insertion.test.ts packages/client-web/src/session-capabilities.test.ts packages/client-web/src/workbench-notice-contract.test.ts packages/client-web/src/sidebar-layout-contract.test.ts packages/client-web/src/sidebar-view-model.test.ts packages/client-web/src/inspector-performance.test.ts packages/client-web/src/session-history-dialog.test.ts packages/client-web/src/components/chat/markdown-blocks.test.ts packages/client-web/src/components/chat/virtualized-feed-layout.test.ts",
    "test:runtime": "node --import tsx --test --test-force-exit packages/runtime-daemon/src/provider-activity.test.ts packages/runtime-daemon/src/provider-diagnostics.test.ts packages/runtime-daemon/src/provider-resume.test.ts packages/runtime-daemon/src/rah-event-contract.test.ts packages/runtime-daemon/src/debug-engine.test.ts packages/runtime-daemon/src/workbench-state.test.ts packages/runtime-daemon/src/runtime-engine.test.ts packages/runtime-daemon/src/line-history-pager.test.ts packages/runtime-daemon/src/line-history-checkpoint.test.ts packages/runtime-daemon/src/terminal-wrapper-control.test.ts packages/runtime-daemon/src/terminal-wrapper-remote-control.test.ts packages/runtime-daemon/src/terminal-wrapper-panel.test.ts packages/runtime-daemon/src/native-terminal-process.test.ts packages/runtime-daemon/src/codex-terminal-wrapper-bridge.test.ts packages/runtime-daemon/src/codex-fixtures.test.ts packages/runtime-daemon/src/codex-history-liveness.test.ts packages/runtime-daemon/src/codex-rollout-activity.test.ts packages/runtime-daemon/src/codex-app-server-activity.test.ts packages/runtime-daemon/src/codex-adapter.test.ts packages/runtime-daemon/src/codex-live-client.test.ts packages/runtime-daemon/src/codex-stored-sessions.test.ts packages/runtime-daemon/src/codex-wrapper-home.test.ts packages/runtime-daemon/src/opencode-acp-activity.test.ts packages/runtime-daemon/src/opencode-activity.test.ts packages/runtime-daemon/src/opencode-live-client.test.ts packages/runtime-daemon/src/opencode-stored-sessions.test.ts packages/runtime-daemon/src/claude-terminal-wrapper-history.test.ts packages/runtime-daemon/src/claude-session-files.test.ts packages/runtime-daemon/src/claude-adapter.test.ts packages/runtime-daemon/src/claude-wrapper-home.test.ts packages/runtime-daemon/src/gemini-conversation-utils.test.ts packages/runtime-daemon/src/gemini-history-cache.test.ts packages/runtime-daemon/src/gemini-adapter.test.ts packages/runtime-daemon/src/kimi-session-files.test.ts packages/runtime-daemon/src/kimi-adapter.test.ts",
    "test:smoke:history-claim": "bash scripts/history-claim-smoke.sh",
    "test:smoke:history-long-browser": "bash scripts/history-long-browser-smoke.sh",
    "test:smoke:inspector-browser": "bash scripts/inspector-browser-smoke.sh",
    "test:smoke:terminal": "tsx scripts/terminal_smoke.ts",
    "test:smoke:terminal-browser": "bash scripts/terminal-browser-smoke.sh",
    "test:smoke:tool-flow": "bash scripts/tool-flow-smoke.sh",
    "test:smoke:gemini-flow": "bash scripts/gemini-flow-smoke.sh",
    "test:smoke:gemini-browser": "bash scripts/gemini-browser-smoke.sh",
    "test:smoke:kimi-flow": "tsx scripts/kimi_flow_smoke.ts",
    "test:smoke:kimi-browser": "bash scripts/kimi-browser-smoke.sh",
    "test:smoke:claude-flow": "bash scripts/claude-flow-smoke.sh",
    "test:smoke:claude-browser": "bash scripts/claude-browser-smoke.sh"
  },
  "dependencies": {
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
