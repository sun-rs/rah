{
  "name": "rah",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:web": "bun --cwd packages/client-web vite build",
    "dev:web": "bun --cwd packages/client-web vite",
    "dev:daemon": "bun --cwd packages/runtime-daemon src/main.ts",
    "serve:workbench": "bun run build:web && bun --cwd packages/runtime-daemon src/main.ts",
    "typecheck": "bunx tsc -p packages/runtime-protocol/tsconfig.json --noEmit && bunx tsc -p packages/runtime-daemon/tsconfig.json --noEmit && bunx tsc -p packages/client-web/tsconfig.json --noEmit",
    "test:web": "bun test packages/client-web/src/types.test.ts packages/client-web/src/useSessionStore.test.ts packages/client-web/src/workbench-selectors.test.ts packages/client-web/src/composer-contract.test.ts packages/client-web/src/workbench-notice-contract.test.ts packages/client-web/src/sidebar-layout-contract.test.ts packages/client-web/src/sidebar-view-model.test.ts packages/client-web/src/inspector-performance.test.ts",
    "test:runtime": "bun test packages/runtime-daemon/src/provider-activity.test.ts packages/runtime-daemon/src/provider-diagnostics.test.ts packages/runtime-daemon/src/rah-event-contract.test.ts packages/runtime-daemon/src/debug-engine.test.ts packages/runtime-daemon/src/workbench-state.test.ts packages/runtime-daemon/src/runtime-engine.test.ts packages/runtime-daemon/src/line-history-pager.test.ts packages/runtime-daemon/src/line-history-checkpoint.test.ts packages/runtime-daemon/src/codex-fixtures.test.ts packages/runtime-daemon/src/codex-rollout-activity.test.ts packages/runtime-daemon/src/codex-app-server-activity.test.ts packages/runtime-daemon/src/codex-adapter.test.ts packages/runtime-daemon/src/codex-live-client.test.ts packages/runtime-daemon/src/codex-stored-sessions.test.ts packages/runtime-daemon/src/claude-session-files.test.ts packages/runtime-daemon/src/claude-adapter.test.ts packages/runtime-daemon/src/gemini-history-cache.test.ts packages/runtime-daemon/src/gemini-adapter.test.ts packages/runtime-daemon/src/kimi-session-files.test.ts packages/runtime-daemon/src/kimi-adapter.test.ts",
    "test:smoke:history-claim": "bash scripts/history-claim-smoke.sh",
    "test:smoke:inspector-browser": "bash scripts/inspector-browser-smoke.sh",
    "test:smoke:tool-flow": "bash scripts/tool-flow-smoke.sh",
    "test:smoke:gemini-flow": "bash scripts/gemini-flow-smoke.sh",
    "test:smoke:gemini-browser": "bash scripts/gemini-browser-smoke.sh",
    "test:smoke:kimi-flow": "bun scripts/kimi_flow_smoke.ts",
    "test:smoke:kimi-browser": "bash scripts/kimi-browser-smoke.sh",
    "test:smoke:claude-flow": "bash scripts/claude-flow-smoke.sh",
    "test:smoke:claude-browser": "bash scripts/claude-browser-smoke.sh"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
